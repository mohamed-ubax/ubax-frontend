{
  "name": "shared-api-types",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/api-types/src",
  "projectType": "library",
  "tags": [
    "scope:shared",
    "type:api-types"
  ],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node scripts/sanitize-openapi-spec.mjs",
          "node scripts/prepare-api-types-output.mjs",
          "ng-openapi-gen --config ng-openapi-gen.json"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "sync": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/sync-api-types.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}