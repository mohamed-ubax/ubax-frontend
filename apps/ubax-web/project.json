{
  "name": "ubax-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "ubax-web",
  "sourceRoot": "apps/ubax-web/src",
  "tags": [
    "scope:web",
    "type:app"
  ],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/ubax-web",
        "browser": "apps/ubax-web/src/main.ts",
        "tsConfig": "apps/ubax-web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "baseHref": "/app/",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ubax-web/public"
          }
        ],
        "styles": [
          "apps/ubax-web/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/ubax-web/src/environments/environment.ts",
              "with": "apps/ubax-web/src/environments/environment.prod.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            }
          ],
          "outputHashing": "all"
        },
        "staging": {
          "fileReplacements": [
            {
              "replace": "apps/ubax-web/src/environments/environment.ts",
              "with": "apps/ubax-web/src/environments/environment.prod.ts"
            }
          ],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": false,
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "port": 4201
      },
      "configurations": {
        "production": {
          "buildTarget": "ubax-web:build:production"
        },
        "development": {
          "buildTarget": "ubax-web:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ubax-web:build",
        "port": 4201,
        "staticFilePath": "dist/apps/ubax-web/browser",
        "spa": true
      }
    }
  }
}