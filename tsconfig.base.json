{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ubax-workspace/ubax-portal-layout": [
        "libs/ubax-portal/layout/src/index.ts"
      ],
      "@ubax-workspace/ubax-portal-features": [
        "libs/ubax-portal/features/src/index.ts"
      ],
      "@ubax-workspace/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@ubax-workspace/shared-api-types": [
        "libs/shared/api-types/src/index.ts"
      ],
      "@ubax-workspace/shared-data-access": [
        "libs/shared/data-access/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-shell": ["libs/ubax-web/shell/src/index.ts"],
      "@ubax-workspace/ubax-web-shell/web-routes": [
        "libs/ubax-web/shell/src/lib/web.routes.ts"
      ],
      "@ubax-workspace/ubax-web-shell/interceptors": [
        "libs/ubax-web/shell/src/lib/interceptors/auth.interceptor.ts"
      ],
      "@ubax-workspace/ubax-web-shell/theme": [
        "libs/ubax-web/shell/src/lib/theme/ubax-preset.ts"
      ],
      "@ubax-workspace/ubax-web-data-access": [
        "libs/ubax-web/data-access/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-dashboard": [
        "libs/ubax-web/features/dashboard/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-immobilier": [
        "libs/ubax-web/features/immobilier/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-location": [
        "libs/ubax-web/features/location/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-finance": [
        "libs/ubax-web/features/finance/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-hotel": [
        "libs/ubax-web/features/hotel/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-espaces": [
        "libs/ubax-web/features/espaces/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-demandes": [
        "libs/ubax-web/features/demandes/src/index.ts"
      ],
      "@ubax-workspace/ubax-web-archivage": [
        "libs/ubax-web/features/archivage/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
